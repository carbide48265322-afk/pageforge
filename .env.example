# PageForge 环境变量配置
# 复制此文件为 .env 并填入实际值

# ─── LLM 配置 ───────────────────────────────────────
# OpenAI 兼容 API 密钥（火山引擎方舟、OpenAI 等）
OPENAI_API_KEY=

# OpenAI 兼容 API 基础 URL（留空则使用 OpenAI 默认地址）
# 火山引擎示例: https://ark.cn-beijing.volces.com/api/v3
OPENAI_BASE_URL=

# 执行模型 — 用于 ReAct 循环生成 HTML（需要 thinking 能力）
# 默认: gpt-4o
MODEL_NAME=

# 意图识别模型 — 轻量快速，不需要 thinking
# 默认: gpt-4o-mini
INTENT_MODEL_NAME=
